@model FlexPulse.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit User Roles</h1>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" value="@Model.Email" readonly />
    </div>
    <div class="mb-3">
        <label class="form-label">Full name</label>
        <input class="form-control" name="FullName" value="@Model.FullName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Date of birth</label>
        <input type="date" class="form-control" name="DateOfBirth" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" />
    </div>

    <div class="mb-3">
        <label class="form-label">Gender</label>
        <select class="form-select" name="Gender">
            <option value="">Select...</option>
            @if (Model.Gender == "Male")
            {
                <option value="Male" selected>Male</option>
            }
            else
            {
                <option value="Male">Male</option>
            }
            @if (Model.Gender == "Female")
            {
                <option value="Female" selected>Female</option>
            }
            else
            {
                <option value="Female">Female</option>
            }
            @if (Model.Gender == "Other")
            {
                <option value="Other" selected>Other</option>
            }
            else
            {
                <option value="Other">Other</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Mobile number</label>
        <input class="form-control" name="MobileNumber" value="@Model.MobileNumber" />
    </div>

    <div class="mb-3">
        <label class="form-label">Roles</label>
        @foreach (var r in Model.AllRoles)
        {
            <div class="form-check">
                @if (Model.Roles?.Contains(r) == true)
                {
                    <input class="form-check-input" type="checkbox" name="Roles" value="@r" id="role_@r" checked />
                }
                else
                {
                    <input class="form-check-input" type="checkbox" name="Roles" value="@r" id="role_@r" />
                }
                <label class="form-check-label" for="role_@r">@r</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>

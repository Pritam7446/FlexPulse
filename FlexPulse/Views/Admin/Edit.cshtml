@model FlexPulse.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit User Roles</h1>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" value="@Model.Email" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Roles</label>
        @foreach (var r in Model.AllRoles)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="Roles" value="@r" id="role_@r" @(Model.Roles?.Contains(r) == true ? "checked" : "") />
                <label class="form-check-label" for="role_@r">@r</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>

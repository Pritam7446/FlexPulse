@model List<FlexPulse.ViewModels.AdminUserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<h1>User Management</h1>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>UserName</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
        <tr>
            <td>@u.Email</td>
            <td>@u.UserName</td>
            <td>
                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@u.Id">Details</a>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@u.Id">Edit</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@u.Id" />
                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user?');">Delete</button>
                </form>
            </td>
        </tr>
        }
    </tbody>
</table>

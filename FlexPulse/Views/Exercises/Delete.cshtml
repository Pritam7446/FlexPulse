@model FlexPulse.Models.Exercise
@{
    ViewData["Title"] = "Delete Exercise";
}

<h1>Delete Exercise</h1>

<div class="alert alert-warning">Are you sure you want to delete this exercise?</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>
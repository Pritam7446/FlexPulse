@model FlexPulse.Models.Exercise
@{
    ViewData["Title"] = "Edit Exercise";
}

<h1>Edit Exercise</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="MuscleGroup" class="form-label"></label>
        <input asp-for="MuscleGroup" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Equipment" class="form-label"></label>
        <input asp-for="Equipment" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="CaloriesPerMinute" class="form-label"></label>
        <input asp-for="CaloriesPerMinute" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1>Dashboard</h1>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Sessions</h5>
                    <p class="card-text display-6">@ViewData["TotalSessions"]</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Active Minutes</h5>
                    <p class="card-text display-6">@ViewData["ActiveMinutes"]</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">Calories Burned</h5>
                    <p class="card-text display-6">@ViewData["Calories"]</p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mt-4">Exercises</h3>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Muscle Group</th>
                <th>Equipment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ex in (List<FlexPulse.Models.Exercise>)ViewData["Exercises"]) {
                <tr>
                    <td>@ex.Name</td>
                    <td>@ex.MuscleGroup</td>
                    <td>@ex.Equipment</td>
                </tr>
            }
        </tbody>
    </table>
</div>

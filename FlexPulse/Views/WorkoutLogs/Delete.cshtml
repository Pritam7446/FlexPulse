@model FlexPulse.Models.WorkoutLog
@{
    ViewData["Title"] = "Delete Workout Log";
}

<h2>@ViewData["Title"]</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>

        <dt class="col-sm-2">Exercise</dt>
        <dd class="col-sm-10">@Model.Exercise?.Name</dd>

        <dt class="col-sm-2">Duration</dt>
        <dd class="col-sm-10">@Model.DurationMinutes</dd>

        <dt class="col-sm-2">Calories</dt>
        <dd class="col-sm-10">@Model.CaloriesBurned</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
